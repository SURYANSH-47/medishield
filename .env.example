# MediShield AI — Environment Variables
# ======================================
# Copy this file to .env.local (frontend) and configure the values below.
# Never commit .env.local or any file containing real secrets.

# ── Frontend (Next.js / Vercel) ───────────────────────────────────────────────
# The full public URL of your Railway backend.
# Example: https://medishield-backend.up.railway.app
# Set this in your Vercel project → Settings → Environment Variables.
NEXT_PUBLIC_API_URL=https://your-railway-backend.up.railway.app

# ── Backend (FastAPI / Railway) ───────────────────────────────────────────────
# Railway injects PORT automatically — do not set it manually.
# PORT=8000

# Improve log visibility in Railway's log stream.
PYTHONUNBUFFERED=1

# Optional: restrict CORS to your Vercel domain instead of allowing all origins.
# ALLOWED_ORIGINS=https://your-app.vercel.app
